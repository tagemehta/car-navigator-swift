    "Announce 'Waiting for verification' messages." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anunciar mensajes de 'Esperando verificación'"
          }
        }
      }
    },
    "Announce All Detected Cars" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anunciar todos los coches detectados"
          }
        }
