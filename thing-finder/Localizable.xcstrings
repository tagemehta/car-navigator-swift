    "Enable for public transit buses. Matches by route number and agency logo instead of make and model." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilitar para autobuses de transporte público. Coincide por número de ruta y logotipo de la agencia en lugar de por marca y modelo."
          }
        }
      }
    },
    "Enable or disable audio beeps for feedback." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activar o desactivar pitidos de audio para comentarios."
          }
        }
      }
    },
    "Enable or disable haptic pulses for feedback." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activar o desactivar pulsos hápticos para comentarios."
          }
        }
      }
    },
    "Ensure good lighting and point camera at the pickup area. Try the 'Rescan' button." : {
      "localizations" : {
        "es" : {
